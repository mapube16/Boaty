# Server configuration
PORT=3002
NODE_ENV=production
MONGODB_URI=mongodb+srv://USER:PASS@cluster0.mongodb.net/boaty?retryWrites=true&w=majority

# Authentication
JWT_SECRET=your_jwt_secret_here
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=https://your-domain.com

# Bootstrap (POC only — disabled when NODE_ENV=production)
BOOTSTRAP_SECRET=your_bootstrap_secret_here

# Email (MailerSend)
MAILERSEND_API_KEY=your_mailersend_api_key
MAILERSEND_FROM=info@your-verified-domain.mlsender.net

# App base URL for invite links and payment back_urls
APP_BASE_URL=https://your-domain.com

# MercadoPago
MP_ACCESS_TOKEN=APP_USR-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Webhook secret for signature verification (found in MP developer dashboard)
MP_WEBHOOK_SECRET=your_mp_webhook_secret_here

# WhatsApp (Twilio)
# Crea cuenta en https://www.twilio.com y activa el Sandbox de WhatsApp
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
# Numero sandbox (cambia al sender aprobado en produccion):
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# SID del template pre-aprobado (Appointment Reminders del sandbox):
TWILIO_CONTENT_SID=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Cloudinary (image uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
