# Server configuration
PORT=3002
MONGODB_URI=mongodb+srv://USER:PASS@cluster0.mongodb.net/boaty

# Email (Resend)
# Email (MailerSend)
MAILERSEND_API_KEY=your_mailersend_api_key
MAILERSEND_FROM=info@domain.com

# App base URL for invite links
APP_BASE_URL=http://localhost:3000

# Auth
JWT_SECRET=change_this_secret
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d

# Bootstrap (POC only)
BOOTSTRAP_SECRET=change_this_bootstrap_secret
